#!/bin/bash
# secret — CLI for Secret Holder's local API (unix socket, current user only).
#
#   secret list                     list all items (never touches secrets)
#   secret get <name>               full item as JSON (TouchID for secrets)
#   secret get <name> -f <field>    single field, plain text
#                                   (TouchID only if the field is a secret)
#
# Examples:
#   export OPENAI_API_KEY=$(secret get openai/prod -f apikey)
#   secret get deploy-server -f password

set -euo pipefail

SOCK="$HOME/.wallet-address-book/api.sock"

usage() {
  sed -n '2,11p' "$0" | sed 's/^# \{0,1\}//'
  exit 1
}

api() {
  curl -sS --fail-with-body --unix-socket "$SOCK" "$@"
}

[ $# -ge 1 ] || usage

cmd="$1"; shift

case "$cmd" in
  list)
    api http://localhost/items
    echo
    ;;
  get)
    [ $# -ge 1 ] || usage
    name="$1"; shift
    field=""
    while [ $# -gt 0 ]; do
      case "$1" in
        -f|--field) field="$2"; shift 2 ;;
        *) usage ;;
      esac
    done
    if [ -n "$field" ]; then
      api -G http://localhost/item --data-urlencode "name=$name" --data-urlencode "field=$field"
      echo
    else
      api -G http://localhost/item --data-urlencode "name=$name"
      echo
    fi
    ;;
  *)
    usage
    ;;
esac
